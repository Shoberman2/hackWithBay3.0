# Neo4j Aura (Free tier)
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Butterbase (auth, DB, AI gateway, payments)
BUTTERBASE_APP_ID=
BUTTERBASE_ANON_KEY=
BUTTERBASE_AI_KEY=
BUTTERBASE_API_URL=https://api.butterbase.ai

# RocketRide Cloud (pipeline hosting)
ROCKETRIDE_APIKEY=
ROCKETRIDE_URI=https://cloud.rocketride.ai
# Deployed pipeline HTTP webhook trigger URL — the managed production endpoint.
# Preferred over the SDK filepath-upload path. Deploy pipelines/rivalry-extract.pipe
# to cloud.rocketride.ai (see pipelines/README.md) and paste the webhook URL here;
# it includes the ?auth=<public token> query param. Requires DEMO_MODE=false.
# ROCKETRIDE_ENDPOINT=https://cloud.rocketride.ai/webhook/rivalry-extract?auth=<public_auth>
ROCKETRIDE_ENDPOINT=

# Daytona (sandboxed analysis scripts for quantitative agent questions)
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=

# Data sources
GITHUB_TOKEN=
PRODUCTHUNT_TOKEN=

# App behavior
# DEMO_MODE=true runs the app end-to-end with zero credentials (fixtures + canned responses)
DEMO_MODE=true
# PUBLIC_DEMO=true relaxes ONLY auth + payments (no login wall, fake-instant
# checkout so nobody is charged) while the LLM gateway, Daytona, and RocketRide
# stay live. Use for public demo deploys; leave false in real production.
PUBLIC_DEMO=false
DEBUG=false
