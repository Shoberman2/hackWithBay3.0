{
  "pipeline": {
    "description": "Rivalry news monitor classification: webhook JSON in -> prompt -> LLM via Butterbase gateway -> NewsSignal JSON out (answers lane).",
    "version": 1,
    "project_id": "rivalry-monitor",
    "source": "webhook_1",
    "components": [
      {
        "id": "webhook_1",
        "provider": "webhook",
        "name": "Input",
        "description": "Source node. Receives the application/json payload sent via the rocketride SDK (client.send, mimetype application/json).",
        "config": {
          "mode": "Source"
        },
        "ui": {
          "position": {
            "x": 80,
            "y": 200
          }
        }
      },
      {
        "id": "prompt_1",
        "provider": "prompt",
        "name": "Instructions",
        "description": "Prepends the system instructions to the incoming JSON payload (the 'questions' lane) before the LLM.",
        "config": {
          "instructions": [
            "You are the classification stage of a competitive-landscape news monitor. Input: JSON with { companies: string[] (the watchlist), tags: string[] (the market), raw_documents: [{ url, source_type, title, text, date? }] } where documents were fetched from TechCrunch, Google News, and Hacker News. Output: ONLY a single JSON object {\"signals\":[{\"headline\":string,\"url\":string,\"date\":string|null,\"source\":string,\"kind\":\"funding\"|\"launch\"|\"acquisition\"|\"shutdown\"|\"product\"|\"market\"|\"other\",\"companies_mentioned\":string[],\"relevance\":number,\"summary\":string}]}. No markdown, no prose, no code fences.\nHard rules: 1. Only emit a signal for a document that concerns a watchlist company OR the market described by the tags; drop everything else silently. 2. url and date are copied verbatim from the input document; never invent URLs or dates. 3. relevance is 0-1: 1.0 = directly about a watchlist company, 0.5 = same market different company, below 0.3 = do not emit. 4. companies_mentioned contains only names actually present in the document text. 5. summary is one factual sentence grounded in the document text; no speculation. 6. kind reflects the document's primary event: funding rounds -> funding, product/feature releases -> launch/product, acquisitions -> acquisition, shutdowns/pivots -> shutdown, market/industry analysis -> market, anything else -> other. 7. Deduplicate: one signal per underlying story even when several documents cover it (keep the highest-relevance document's url)."
          ]
        },
        "input": [
          {
            "lane": "questions",
            "from": "webhook_1"
          }
        ],
        "ui": {
          "position": {
            "x": 360,
            "y": 200
          }
        }
      },
      {
        "id": "llm_1",
        "provider": "llm_openai_api",
        "name": "LLM (Butterbase gateway)",
        "description": "OpenAI-compatible LLM node pointed at the Butterbase gateway. The API key is injected at use() time as ${ROCKETRIDE_BUTTERBASE_AI_KEY}; no raw provider keys in the file.",
        "config": {
          "profile": "custom",
          "custom": {
            "apikey": "${ROCKETRIDE_BUTTERBASE_AI_KEY}",
            "base_url": "https://api.butterbase.ai/v1",
            "model": "anthropic/claude-sonnet-4.5",
            "modelTotalTokens": 8192
          }
        },
        "input": [
          {
            "lane": "questions",
            "from": "prompt_1"
          }
        ],
        "ui": {
          "position": {
            "x": 640,
            "y": 200
          }
        }
      },
      {
        "id": "response_1",
        "provider": "response_answers",
        "name": "JSON out",
        "description": "Returns the LLM's answer text under the 'answers' key as the synchronous pipeline result.",
        "config": {
          "laneName": "answers"
        },
        "input": [
          {
            "lane": "answers",
            "from": "llm_1"
          }
        ],
        "ui": {
          "position": {
            "x": 920,
            "y": 200
          }
        }
      }
    ]
  }
}